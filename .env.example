# Dragon Games — environment template.
# Copy to `.env` and fill in. `.env` is gitignored. Validated at boot by
# `src/env.ts` (set SKIP_ENV_VALIDATION=1 to bypass, e.g. for Docker builds).

# ── Core ─────────────────────────────────────────────────────────────────────
NODE_ENV="development"
# Public base URL of the app (used for absolute links, emails, OG tags).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
# Matches docker-compose.yml (host port 5433).
DATABASE_URL="postgresql://dragon:dragon@localhost:5433/dragon_games?schema=public"
# Used by the integration test suite (#6). Created by docker/postgres/init.
DATABASE_URL_TEST="postgresql://dragon:dragon@localhost:5433/dragon_games_test?schema=public"

# ── Auth (M3 / #11) ──────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=""

# ── Email — Resend (M4/M6) ───────────────────────────────────────────────────
RESEND_API_KEY=""
EMAIL_FROM="Dragon Games <info@dragon.rs>"

# ── Error tracking — Sentry (#5) ─────────────────────────────────────────────
# Leave empty to disable Sentry locally; the SDK no-ops without a DSN.
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
# Only needed in CI/CD to upload source maps.
SENTRY_AUTH_TOKEN=""

# ── Anti-spam — Cloudflare Turnstile (M4 / #18) ──────────────────────────────
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""
